server {
    listen 80;
    server_name YOUR_HOSTNAME_OR_IP;

    client_max_body_size 10M;

    location = /ops-console {
        return 301 /ops-console/;
    }

    location /ops-console/ {
        auth_basic "Student Bot Ops Console";
        auth_basic_user_file /etc/nginx/.htpasswd-ops-console;
        limit_req zone=ops_console burst=8 nodelay;
        limit_except GET POST HEAD { deny all; }
        add_header Cache-Control "no-store" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "no-referrer" always;
        proxy_pass http://127.0.0.1:8091/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /ops-console;
        proxy_set_header Authorization "";
    }
}

